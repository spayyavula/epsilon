<ui:FluentWindow x:Class="Epsilon.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Epsilon.App.ViewModels"
        xmlns:views="clr-namespace:Epsilon.App.Views"
        Title="Epsilon — Mathematics Research Assistant"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocumentsViewModel}">
            <views:DocumentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResearchToolkitViewModel}">
            <views:ResearchToolkitView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SolverViewModel}">
            <views:SolverView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#949;" FontSize="24" Foreground="#63e6be" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Epsilon" FontSize="20" FontWeight="Bold" Foreground="#63e6be" VerticalAlignment="Center"/>
                        <Border Background="#1a3a3a" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="v0.1" FontSize="10" Foreground="#96f2d7"/>
                        </Border>
                    </StackPanel>

                    <Button Content="+ New Chat"
                            Command="{Binding Chat.NewConversationCommand}"
                            HorizontalAlignment="Stretch" Padding="0,8"
                            Background="#20c997" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,8">
                    <Button Content="&#128488;  Chat" Command="{Binding NavigateToChatCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,2"
                            Background="{Binding ActiveTab, Converter={StaticResource TabBrush}, ConverterParameter=Chat}"/>
                    <Button Content="&#128196;  Documents" Command="{Binding NavigateToDocumentsCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,2"
                            Background="{Binding ActiveTab, Converter={StaticResource TabBrush}, ConverterParameter=Documents}"/>
                    <Button Content="&#9999;  Solver" Command="{Binding NavigateToSolverCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,2"
                            Background="{Binding ActiveTab, Converter={StaticResource TabBrush}, ConverterParameter=Solver}"/>
                    <Button Content="&#128300;  Research" Command="{Binding NavigateToToolkitCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,2"
                            Background="{Binding ActiveTab, Converter={StaticResource TabBrush}, ConverterParameter=Toolkit}"/>
                    <Button Content="&#9881;  Settings" Command="{Binding NavigateToSettingsCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,2"
                            Background="{Binding ActiveTab, Converter={StaticResource TabBrush}, ConverterParameter=Settings}"/>
                </StackPanel>

                <!-- Help & Exit Buttons -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                    <Button Content="?  Tour &amp; Help" Click="HelpButton_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8" Margin="0,0,0,4"
                            Background="#1a2a3a" Foreground="#4ca6ff" FontWeight="SemiBold"/>
                    <Button Content="&#10006;  Exit" Click="ExitButton_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Background="#2a1a1a" Foreground="#ff6b6b" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Conversation List -->
                <DockPanel Margin="8,0,8,8">
                    <TextBlock DockPanel.Dock="Top" Text="RECENT CHATS" FontSize="10"
                               Foreground="#666" Margin="8,8,0,4" FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding Chat.Conversations}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="x"
                                            Command="{Binding DataContext.Chat.DeleteConversationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            FontSize="10" Padding="4,2" Opacity="0.5"
                                            Background="Transparent" Foreground="#ff6b6b"/>
                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                               Foreground="#aaa" Cursor="Hand" Padding="4,4">
                                        <TextBlock.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.Chat.SelectConversationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" />
    </Grid>
</ui:FluentWindow>
