<UserControl x:Class="Epsilon.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0f0f23">
        <StackPanel Margin="32,24" MaxWidth="700">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#63e6be" Margin="0,0,0,24"/>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="#20c997" Margin="0,0,0,16"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NonEmptyVisibility}}"/>

            <!-- OpenAI -->
            <Border Background="#1a1a2e" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="OpenAI" FontSize="16" FontWeight="SemiBold" Foreground="#eee"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding OpenAiStatus}" Foreground="#888"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="API Key" Foreground="#999" FontSize="12" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Test" Command="{Binding TestOpenAiCommand}"
                                Margin="8,0,0,0" Padding="12,6"/>
                        <Button DockPanel.Dock="Right" Content="Save" Command="{Binding SaveOpenAiKeyCommand}"
                                Background="#20c997" Foreground="White" Margin="8,0,0,0" Padding="12,6"/>
                        <PasswordBox x:Name="OpenAiKeyBox" Background="#2a2a4a" Foreground="#eee"
                                     BorderBrush="#3a3a5a" Padding="10,8"
                                     PasswordChanged="OpenAiKeyBox_PasswordChanged"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Anthropic -->
            <Border Background="#1a1a2e" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Anthropic" FontSize="16" FontWeight="SemiBold" Foreground="#eee"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding AnthropicStatus}" Foreground="#888"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="API Key" Foreground="#999" FontSize="12" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Test" Command="{Binding TestAnthropicCommand}"
                                Margin="8,0,0,0" Padding="12,6"/>
                        <Button DockPanel.Dock="Right" Content="Save" Command="{Binding SaveAnthropicKeyCommand}"
                                Background="#20c997" Foreground="White" Margin="8,0,0,0" Padding="12,6"/>
                        <PasswordBox x:Name="AnthropicKeyBox" Background="#2a2a4a" Foreground="#eee"
                                     BorderBrush="#3a3a5a" Padding="10,8"
                                     PasswordChanged="AnthropicKeyBox_PasswordChanged"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Gemini -->
            <Border Background="#1a1a2e" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Google Gemini" FontSize="16" FontWeight="SemiBold" Foreground="#eee"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding GeminiStatus}" Foreground="#888"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="API Key" Foreground="#999" FontSize="12" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Test" Command="{Binding TestGeminiCommand}"
                                Margin="8,0,0,0" Padding="12,6"/>
                        <Button DockPanel.Dock="Right" Content="Save" Command="{Binding SaveGeminiKeyCommand}"
                                Background="#20c997" Foreground="White" Margin="8,0,0,0" Padding="12,6"/>
                        <PasswordBox x:Name="GeminiKeyBox" Background="#2a2a4a" Foreground="#eee"
                                     BorderBrush="#3a3a5a" Padding="10,8"
                                     PasswordChanged="GeminiKeyBox_PasswordChanged"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Exa Web Search -->
            <Border Background="#1a1a2e" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Exa Web Search" FontSize="16" FontWeight="SemiBold" Foreground="#eee"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ExaStatus}" Foreground="#888"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Enables web search alongside local document RAG. Get your API key from exa.ai"
                               Foreground="#999" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="API Key" Foreground="#999" FontSize="12" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Test" Command="{Binding TestExaCommand}"
                                Margin="8,0,0,0" Padding="12,6"/>
                        <Button DockPanel.Dock="Right" Content="Save" Command="{Binding SaveExaKeyCommand}"
                                Background="#20c997" Foreground="White" Margin="8,0,0,0" Padding="12,6"/>
                        <PasswordBox x:Name="ExaKeyBox" Background="#2a2a4a" Foreground="#eee"
                                     BorderBrush="#3a3a5a" Padding="10,8"
                                     PasswordChanged="ExaKeyBox_PasswordChanged"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Ollama -->
            <Border Background="#1a1a2e" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Ollama (Local)" FontSize="16" FontWeight="SemiBold" Foreground="#eee"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding OllamaStatus}" Foreground="#888"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="No API key needed — runs locally on your machine." Foreground="#999" FontSize="12" Margin="0,0,0,8"/>
                    <Button Content="Test Connection" Command="{Binding TestOllamaCommand}"
                            Background="#20c997" Foreground="White" Padding="12,6" HorizontalAlignment="Left"/>

                    <Border Background="#2a2a4a" CornerRadius="6" Padding="16" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Setup Instructions" FontWeight="SemiBold" Foreground="#63e6be" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#bbb" FontSize="13">
                                <Run FontWeight="SemiBold" Text="1."/><Run Text=" Download Ollama from "/><Run Text="https://ollama.com/download" Foreground="#63e6be"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="2."/><Run Text=" Run the installer (OllamaSetup.exe)"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="3."/><Run Text=" Open a terminal and pull a model:"/><LineBreak/>
                                <Run Text="     ollama pull llama3.2" FontFamily="Consolas" Foreground="#96f2d7"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="4."/><Run Text=" Ollama runs automatically in the background"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="5."/><Run Text=" Click 'Test Connection' above to verify"/><LineBreak/>
                                <LineBreak/>
                                <Run Text="Recommended models for mathematics:" FontWeight="SemiBold"/><LineBreak/>
                                <Run Text="  llama3.2" FontFamily="Consolas" Foreground="#96f2d7"/><Run Text=" — Good all-around (4.7 GB)"/><LineBreak/>
                                <Run Text="  mistral" FontFamily="Consolas" Foreground="#96f2d7"/><Run Text=" — Fast and capable (4.1 GB)"/><LineBreak/>
                                <Run Text="  phi3" FontFamily="Consolas" Foreground="#96f2d7"/><Run Text=" — Lightweight, good for math (2.3 GB)"/><LineBreak/>
                                <Run Text="  gemma2" FontFamily="Consolas" Foreground="#96f2d7"/><Run Text=" — Google's open model (5.4 GB)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
