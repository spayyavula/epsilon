<Window x:Class="Epsilon.App.Views.WelcomeTourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Welcome to Epsilon" Height="640" Width="860"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#0f0f23" WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="16" Background="#0f0f23" BorderBrush="#2a2a4a" BorderThickness="1">
        <Grid>
            <wv2:WebView2 x:Name="TourWebView" DefaultBackgroundColor="#0f0f23"/>
        </Grid>
    </Border>
</Window>
