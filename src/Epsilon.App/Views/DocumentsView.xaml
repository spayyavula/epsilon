<UserControl x:Class="Epsilon.App.Views.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Epsilon.App.Converters">

    <Grid Background="#0f0f23">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="32,24,32,16">
            <TextBlock Text="Documents" FontSize="24" FontWeight="Bold" Foreground="#63e6be"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ConnectOneDriveCommand}"
                        Background="#1a3a5a" Foreground="#4ca6ff" Padding="16,8"
                        FontWeight="SemiBold" Margin="0,0,8,0"
                        ToolTip="Connect OneDrive folders to your mathematics library"
                        Visibility="{Binding OneDriveAvailable, Converter={StaticResource BoolVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#9729;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="OneDrive"/>
                    </StackPanel>
                </Button>
                <Button Content="+ Link Folder"
                        Command="{Binding LinkFolderCommand}"
                        Background="#2a4a2a" Foreground="#69db7c" Padding="16,8"
                        FontWeight="SemiBold" Margin="0,0,8,0"/>
                <Button Content="+ Add File"
                        Command="{Binding AddDocumentCommand}"
                        Background="#20c997" Foreground="White" Padding="16,8"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </DockPanel>

        <!-- Status Message -->
        <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="#20c997"
                   Margin="32,60,32,0" FontSize="12"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NonEmptyVisibility}}"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,0,32,32">

                <!-- Empty state (no folders and no documents) -->
                <TextBlock Text="No documents yet. Add individual files or link an entire folder to build your mathematics library."
                           Foreground="#666" FontSize="14" Margin="0,40,0,0" TextWrapping="Wrap"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Documents.Count}" Value="0"/>
                                        <Condition Binding="{Binding Folders.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Linked Folders Section -->
                <StackPanel Visibility="{Binding Folders.Count, Converter={StaticResource NonZeroVisibility}}">
                    <TextBlock Text="LIBRARY SOURCES" FontSize="11" FontWeight="SemiBold"
                               Foreground="#666" Margin="0,8,0,8"/>

                    <ItemsControl ItemsSource="{Binding Folders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1a2a1a" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                                        BorderBrush="#2a4a2a" BorderThickness="1">
                                    <DockPanel>
                                        <!-- Actions -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="&#8635;" ToolTip="Rescan folder"
                                                    Command="{Binding DataContext.RefreshFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="16" Padding="8,4" Margin="0,0,4,0"
                                                    Background="Transparent" Foreground="#69db7c"/>
                                            <Button Content="Unlink"
                                                    Command="{Binding DataContext.UnlinkFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="#ff6b6b" Background="Transparent"
                                                    Padding="8,4"/>
                                        </StackPanel>

                                        <!-- Folder info -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#128193;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Label}" FontSize="15"
                                                           FontWeight="SemiBold" Foreground="#69db7c"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Path}" Foreground="#666" FontSize="12"
                                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Border Background="#2a4a2a" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock FontSize="11" Foreground="#69db7c">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} documents">
                                                                <Binding Path="DocumentCount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock FontSize="11" Foreground="#555" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="Scanned: {0:g}">
                                                            <Binding Path="LastScannedAt"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Documents Section -->
                <StackPanel Visibility="{Binding Documents.Count, Converter={StaticResource NonZeroVisibility}}">
                    <TextBlock Text="ALL DOCUMENTS" FontSize="11" FontWeight="SemiBold"
                               Foreground="#666" Margin="0,16,0,8"/>

                    <ItemsControl ItemsSource="{Binding Documents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1a1a2e" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Remove"
                                                Command="{Binding DataContext.RemoveDocumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="#ff6b6b" Background="Transparent"
                                                VerticalAlignment="Center" Padding="8,4"/>

                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="#eee"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding SizeBytes, Converter={StaticResource FileSize}}"
                                                           Foreground="#888" FontSize="12" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding MimeType}" Foreground="#888" FontSize="12" Margin="0,0,12,0"/>
                                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                        Background="{Binding Status, Converter={StaticResource StatusBrush}}">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White"/>
                                                </Border>
                                                <!-- Source label for folder-linked docs -->
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="#2a2a4a"
                                                        Visibility="{Binding FolderId, Converter={StaticResource NonEmptyVisibility}}">
                                                    <TextBlock Text="from folder" FontSize="11" Foreground="#888"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
