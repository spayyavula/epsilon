<UserControl x:Class="Epsilon.App.Views.FlashcardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid Background="#0f0f23">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1" Padding="24,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#949; Flashcards" FontSize="20" FontWeight="Bold" Foreground="#63e6be" Margin="0,0,20,0"/>
                    <Border Background="#1a2a3a" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock Foreground="#4ca6ff" FontSize="12">
                            <Run Text="Due: "/>
                            <Run Text="{Binding DueCount}" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#1a2a3a" CornerRadius="6" Padding="8,4">
                        <TextBlock Foreground="#888" FontSize="12">
                            <Run Text="Total: "/>
                            <Run Text="{Binding TotalCount}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Category:" Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Width="130" FontSize="12"/>
                    <Button Content="&#8635; Refresh" Command="{Binding RefreshCommand}"
                            Background="#1a2a3a" Foreground="#4ca6ff"
                            Padding="10,6" Margin="8,0,0,0" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Add Card Section -->
        <Border Grid.Row="1" Background="#141428" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1" Padding="24,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="+ Add Card" Command="{Binding AddCardCommand}"
                        Background="#20c997" Foreground="White" FontWeight="SemiBold"
                        Padding="14,8" Margin="8,0,0,0" VerticalAlignment="Top"/>
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="8,0,0,0">
                    <TextBlock Text="Category" Foreground="#666" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}"
                             Width="110" Background="#2a2a4a" Foreground="#eee"
                             BorderBrush="#3a3a5a" Padding="8,6" FontSize="13"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Front (theorem / question)" Foreground="#666" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding NewFront, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="56"
                                 Background="#2a2a4a" Foreground="#eee" BorderBrush="#3a3a5a"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Back (proof / explanation)" Foreground="#666" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding NewBack, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="56"
                                 Background="#2a2a4a" Foreground="#eee" BorderBrush="#3a3a5a"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Card Display (WebView2) -->
        <Grid Grid.Row="2">
            <wv2:WebView2 x:Name="CardWebView" DefaultBackgroundColor="#0f0f23"/>
        </Grid>

        <!-- Rating Buttons -->
        <Border Grid.Row="3" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0" Padding="24,12">
            <DockPanel>
                <!-- Show Answer (when front only) -->
                <Button DockPanel.Dock="Left" Content="Show Answer" Command="{Binding ShowAnswerCommand}"
                        Background="#4c6ef5" Foreground="White" FontWeight="SemiBold"
                        Padding="20,10" FontSize="14"
                        Visibility="{Binding IsShowingAnswer, Converter={StaticResource InverseBoolVisibility}}"/>

                <!-- Rating buttons (when answer shown) -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsShowingAnswer, Converter={StaticResource BoolVisibility}}">
                    <Button Content="Hard" Command="{Binding RateHardCommand}"
                            Background="#e03131" Foreground="White" FontWeight="SemiBold"
                            Padding="20,10" Margin="0,0,8,0" FontSize="14"/>
                    <Button Content="Good" Command="{Binding RateGoodCommand}"
                            Background="#f59f00" Foreground="White" FontWeight="SemiBold"
                            Padding="20,10" Margin="0,0,8,0" FontSize="14"/>
                    <Button Content="Easy" Command="{Binding RateEasyCommand}"
                            Background="#20c997" Foreground="White" FontWeight="SemiBold"
                            Padding="20,10" FontSize="14"/>
                </StackPanel>

                <Button DockPanel.Dock="Right" Content="Delete Card" Command="{Binding DeleteCardCommand}"
                        Background="Transparent" Foreground="#ff6b6b"
                        Padding="10,8" FontSize="12"
                        Visibility="{Binding CurrentCard, Converter={StaticResource NullVisibility}}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#666" FontSize="12"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
