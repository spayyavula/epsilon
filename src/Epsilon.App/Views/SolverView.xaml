<UserControl x:Class="Epsilon.App.Views.SolverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid Background="#0f0f23">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1" Padding="24,16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold" Foreground="#63e6be"
                           VerticalAlignment="Center">
                    <Run Text="&#949;" FontSize="26"/>
                    <Run Text=" Equation Solver"/>
                </TextBlock>

                <!-- Provider selector -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Providers}" DisplayMemberPath="Name"
                              SelectedValuePath="Id" SelectedValue="{Binding SelectedProviderId}"
                              Width="120" FontSize="11" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding Models}" DisplayMemberPath="Name"
                              SelectedValuePath="Id" SelectedValue="{Binding SelectedModelId}"
                              Width="140" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="1" Background="#141428" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1" Padding="24,16">
            <DockPanel>
                <!-- Buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,0,0,0">
                    <Button Content="Solve" Command="{Binding SolveCommand}"
                            Background="#20c997" Foreground="White" FontWeight="Bold"
                            Padding="20,10" FontSize="15"
                            Visibility="{Binding IsSolving, Converter={StaticResource InverseBoolVisibility}}"/>
                    <Button Content="Stop" Command="{Binding CancelCommand}"
                            Background="#e03131" Foreground="White" FontWeight="Bold"
                            Padding="20,10" FontSize="15"
                            Visibility="{Binding IsSolving, Converter={StaticResource BoolVisibility}}"/>
                    <Button Content="Clear" Command="{Binding ClearCommand}"
                            Padding="12,10" FontSize="13" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Input -->
                <StackPanel>
                    <TextBlock Text="Enter an equation, expression, integral, or any mathematical problem:"
                               Foreground="#888" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EquationInput, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100"
                             VerticalScrollBarVisibility="Auto"
                             Background="#2a2a4a" Foreground="#eee" BorderThickness="1"
                             BorderBrush="#3a3a5a" Padding="14,10" FontSize="16"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             CaretBrush="#20c997"
                             KeyDown="InputBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#666" FontSize="11"/>
                        <TextBlock Text="  |  Enter to solve, Shift+Enter for new line" Foreground="#444" FontSize="11"
                                   Visibility="{Binding IsSolving, Converter={StaticResource InverseBoolVisibility}}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Solution Display -->
        <Grid Grid.Row="2">
            <wv2:WebView2 x:Name="SolverWebView" DefaultBackgroundColor="#0f0f23"/>

            <!-- Empty state -->
            <Border Background="#0f0f23" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding StreamingContent, Converter={StaticResource EmptyVisibility}}">
                <Border Background="#1e1e3a" CornerRadius="12" Padding="48,40"
                        Visibility="{Binding IsSolving, Converter={StaticResource InverseBoolVisibility}}">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="500">
                        <TextBlock Text="&#949;" FontSize="48" HorizontalAlignment="Center"
                                   Foreground="#20c997" Margin="0,0,0,16"/>
                        <TextBlock Text="Type any equation and click Solve" Foreground="#888"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Examples:" Foreground="#666" FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Cursor="Hand"
                                   MouseLeftButtonDown="Example_Click" Tag="x^2 + 5x + 6 = 0">
                            <Run Text="  x² + 5x + 6 = 0" FontFamily="Cascadia Code, Consolas"/>
                        </TextBlock>
                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Cursor="Hand" Margin="0,4,0,0"
                                   MouseLeftButtonDown="Example_Click" Tag="integrate sin(x) * e^x dx">
                            <Run Text="  ∫ sin(x)·eˣ dx" FontFamily="Cascadia Code, Consolas"/>
                        </TextBlock>
                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Cursor="Hand" Margin="0,4,0,0"
                                   MouseLeftButtonDown="Example_Click" Tag="solve the system: 2x + 3y = 7, x - y = 1">
                            <Run Text="  2x + 3y = 7, x - y = 1" FontFamily="Cascadia Code, Consolas"/>
                        </TextBlock>
                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Cursor="Hand" Margin="0,4,0,0"
                                   MouseLeftButtonDown="Example_Click" Tag="find the limit as x approaches 0 of sin(x)/x">
                            <Run Text="  lim(x→0) sin(x)/x" FontFamily="Cascadia Code, Consolas"/>
                        </TextBlock>
                        <TextBlock Foreground="#555" FontSize="13" TextWrapping="Wrap" Cursor="Hand" Margin="0,4,0,0"
                                   MouseLeftButtonDown="Example_Click" Tag="solve the differential equation y' + 2y = e^(-x)">
                            <Run Text="  y' + 2y = e⁻ˣ" FontFamily="Cascadia Code, Consolas"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
