<UserControl x:Class="Epsilon.App.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid Background="#0f0f23">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- WebView2 Chat Display -->
        <wv2:WebView2 x:Name="ChatWebView" Grid.Row="0"
                      DefaultBackgroundColor="#0f0f23" />

        <!-- Input Bar -->
        <Border Grid.Row="1" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                Padding="16,12">
            <DockPanel>
                <!-- Model info -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Background="#2a2a4a" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                        <TextBlock Text="{Binding SelectedProviderId}" FontSize="11" Foreground="#888"/>
                    </Border>
                    <Border Background="#2a2a4a" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                        <TextBlock Text="{Binding SelectedModelId}" FontSize="11" Foreground="#888"/>
                    </Border>

                    <!-- Provider selector -->
                    <ComboBox ItemsSource="{Binding Providers}" DisplayMemberPath="Name"
                              SelectedValuePath="Id" SelectedValue="{Binding SelectedProviderId}"
                              Width="140" FontSize="11" Margin="8,0,0,0"/>
                    <ComboBox ItemsSource="{Binding Models}" DisplayMemberPath="Name"
                              SelectedValuePath="Id" SelectedValue="{Binding SelectedModelId}"
                              Width="160" FontSize="11" Margin="4,0,0,0"/>

                    <!-- Web Search Toggle -->
                    <Border Background="{Binding WebSearchEnabled, Converter={StaticResource WebToggleBrush}}"
                            CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                            Cursor="Hand" MouseLeftButtonDown="WebToggle_Click"
                            Visibility="{Binding WebSearchAvailable, Converter={StaticResource BoolVisibility}}"
                            ToolTip="Toggle Exa web search alongside local documents">
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding WebSearchEnabled, Converter={StaticResource WebToggleFg}}">
                            <TextBlock.Text>
                                <Binding Path="WebSearchEnabled"
                                         Converter="{StaticResource WebToggleText}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                    <TextBlock Text="Shift+Enter for new line" Foreground="#555" FontSize="10"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Send / Stop buttons -->
                <Grid DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Bottom">
                    <Button Padding="16,10"
                            Background="#20c997" Foreground="White" FontWeight="SemiBold"
                            Command="{Binding SendMessageCommand}" Content="Send"
                            Visibility="{Binding IsStreaming, Converter={StaticResource InverseBoolVisibility}}"/>
                    <Button Padding="16,10"
                            Background="#e03131" Foreground="White" FontWeight="SemiBold"
                            Command="{Binding StopStreamingCommand}" Content="Stop"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BoolVisibility}}"/>
                </Grid>

                <!-- Text input -->
                <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                         MaxHeight="150" VerticalScrollBarVisibility="Auto"
                         Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2a2a4a" Foreground="#eee" BorderThickness="1"
                         BorderBrush="#3a3a5a" Padding="12,10"
                         FontSize="14" CaretBrush="White"
                         KeyDown="InputBox_KeyDown"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
