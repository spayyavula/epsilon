<Window x:Class="Epsilon.App.Views.OneDrivePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect OneDrive Folders" Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#0f0f23" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="&#9729;" FontSize="22" Foreground="#4ca6ff" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="OneDrive" FontSize="20" FontWeight="Bold" Foreground="#4ca6ff" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Select folders from your OneDrive to add to your mathematics library. Documents will be indexed for search and Q&amp;A."
                       Foreground="#999" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- OneDrive path -->
        <Border Grid.Row="1" Background="#1a2a3a" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <TextBlock Text="{Binding OneDrivePath}" Foreground="#4ca6ff" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Folder list with checkboxes -->
        <Border Grid.Row="2" Background="#1a1a2e" CornerRadius="8" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Folders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                              Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               Foreground="#666" FontSize="12">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} files">
                                                <Binding Path="DocumentCount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14"
                                                   Foreground="#eee" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <Button DockPanel.Dock="Right" Content="Link Selected" Click="LinkButton_Click"
                    Background="#20c997" Foreground="White" Padding="20,10"
                    FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="Cancel" Click="CancelButton_Click"
                    Padding="20,10" Margin="0,0,8,0"/>
            <StackPanel/>
        </DockPanel>
    </Grid>
</Window>
